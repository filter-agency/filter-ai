{
  "version": "1.7.0",
  "name": "filter-agency/filter-ai",
  "description": "Powerful AI content creation tools integrated directly into the WordPress editor for effortless content generation.",
  "type": "wordpress-plugin",
  "dist": {
    "url": "https://github.com/filter-agency/filter-ai/releases/latest/download/filter-ai.zip",
    "type": "zip"
  },
  "license": "GPL-3.0",
  "require": {
    "php": ">=7.4",
    "composer/installers": "~1.0",
    "woocommerce/action-scheduler": "^3.9",
    "stellarwp/telemetry": "^2.4",
    "stellarwp/container-contract": "^1.1",
    "lucatume/di52": "^4.0"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "require-dev": {
    "wp-coding-standards/wpcs": "^3.0",
    "brianhenryie/strauss": "^0.21"
  },
  "autoload-dev": {
    "psr-4": {
      "Composer\\": "vendor/composer/composer/src/Composer/"
    }
  },
  "scripts": {
    "check-cs": [
      "@php ./vendor/bin/phpcs"
    ],
    "fix-cs": [
      "@php ./vendor/bin/phpcbf"
    ],
    "strauss": [
      "vendor/bin/strauss"
    ],
    "post-install-cmd": [
      "@strauss",
      "npm install",
      "npm run build"
    ],
    "post-update-cmd": [
      "@strauss"
    ]
  },
  "extra": {
    "installer-paths": {
      "packages/{$name}": [
        "woocommerce/action-scheduler"
      ]
    },
    "strauss": {
      "target_directory": "vendor-prefixed",
      "namespace_prefix": "Filter_AI\\Vendor\\",
      "classmap_prefix": "Filter_AI_Vendor_",
      "constant_prefix": "FILTER_AI_VENDOR_",
      "packages": [
        "stellarwp/telemetry",
        "stellarwp/container-contract",
        "lucatume/di52"
      ],
      "delete_vendor_packages": true
    }
  }
}
